# ===========================================
# WoW Hotel Des Ventes Trading Bot - Configuration
# ===========================================

# Blizzard API Credentials
# Créez votre app sur https://develop.battle.net/
BLIZZARD_CLIENT_ID=your_client_id_here
BLIZZARD_CLIENT_SECRET=your_client_secret_here

# Blizzard API Region & Realm
BLIZZARD_REGION=eu
BLIZZARD_REALM_SLUG=archimonde
BLIZZARD_CONNECTED_REALM_ID=1302
BLIZZARD_LOCALE=fr_FR

# Discord Bot
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_channel_id_here

# Database
DATABASE_URL=sqlite:///./data/wow_ah.db

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
FRONTEND_URL=http://localhost:4200

# Trading Settings
# Seuil minimum de profit en % pour signaler une bonne affaire
MIN_PROFIT_MARGIN=20
# Nombre max d'items à surveiller
MAX_TRACKED_ITEMS=500
# Budget max en gold pour les suggestions d'achat
MAX_BUDGET_GOLD=500000
# Intervalle de scan en minutes
SCAN_INTERVAL_MINUTES=60
