# ===========================================
# WoW AH Trading Bot (Go) - Configuration
# ===========================================
# Copy this file to .env and fill in your values

# Blizzard API Credentials
# Create your app at https://develop.battle.net/
BLIZZARD_CLIENT_ID=your_client_id_here
BLIZZARD_CLIENT_SECRET=your_client_secret_here

# Blizzard API Region & Realm
BLIZZARD_REGION=eu
BLIZZARD_REALM_SLUG=archimonde
BLIZZARD_CONNECTED_REALM_ID=1302
BLIZZARD_LOCALE=fr_FR

# Discord Bot
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_channel_id_here

# Database (SQLite path)
DATABASE_PATH=./data/wow_ah.db

# Backend Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:4200

# Trading Settings
MIN_PROFIT_MARGIN=20
MAX_TRACKED_ITEMS=500
MAX_BUDGET_GOLD=500000
SCAN_INTERVAL_MINUTES=60
